SELECT *
FROM
(
    SELECT
        id,
        platform,
        followers,
        ROW_NUMBER() OVER(
            PARTITION BY platform
            ORDER BY followers DESC
        ) AS Row_Num
    FROM Influencers
) AS RankedInfluencers
WHERE Row_Num <= 3;
